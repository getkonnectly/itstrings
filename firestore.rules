rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leads (project + staffing requests)
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Candidate profiles
    match /candidates/{candidateId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
